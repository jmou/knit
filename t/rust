#!/bin/bash -ex

if [[ -z $USE_RUST ]]; then
    exit
fi

invocation=$(./run-flow flow/basic/tac.unit)

diff - <(./rust print invocation $invocation | cut -d= -f1) <<EOF
_annotated_plan
plan
production
status
EOF

./rust print invocation $invocation | grep -qx status=ok

production=$(./rust print invocation $invocation | grep ^production= | cut -d= -f2)

diff - <(./rust print production $production | cut -d= -f1) <<EOF
_source
dep:in/data
end_ts
exit_code
job
out/_
start_ts
EOF

job=$(./rust print production $production | grep ^job= | cut -d= -f2)

diff - <(./rust print job $job) <<EOF
in/data=01e79c32a8c99c557f0757da7cb6d65b3414466d
process=command:perl -e 'print reverse <>' in/data > out/_
EOF

# flow/basic/source.unit (synthesized identity job)
diff - <(./rust run-job 7c0d72850f36e7338fba64f8434e024c57520019) <<EOF
exit_code=0
job=7c0d72850f36e7338fba64f8434e024c57520019
out/_=01e79c32a8c99c557f0757da7cb6d65b3414466d
EOF
