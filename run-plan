#!/bin/bash -e
#
# Run an execution plan.

plan=$1

if [[ $USE_RUST -eq 1 ]]; then
    exec cargo run run-plan $plan
fi

set -o pipefail

initial_plan=$(./kgit hash-object -w --stdin < $plan)
while ./schedule-step < $plan > gen/next; do
    # TODO allow manual jobs
    pos=$(head -n1 gen/next)

    ./extract-step $plan $pos > gen/step
    source=$(grep ^_source= gen/step | cut -d= -f2) || true
    # Convert step to job.
    grep -v ^_ gen/step | sort > gen/job
    job=$(./kgit hash-object -w --stdin < gen/job)

    # TODO more nuanced caching policy
    if production=$(./kgit rev-parse --verify -q refs/job/$job/lastproduction); then
        ./kgit cat-file blob $production > gen/production.$$
    else
        echo Running job:$job $source >&2
        ./run-job < gen/job > gen/production.$$
        echo -e "_source=$source\njob=$job" >> gen/production.$$
        ./extract-step $plan $pos | grep ^_dep: | sed s/^_// >> gen/production.$$ || true
        production=$(sort gen/production.$$ | ./kgit hash-object -w --stdin)
        ./kgit update-ref refs/job/$job/lastproduction $production
    fi

    exit_code=$(grep ^exit_code= gen/production.$$ | cut -d= -f2)
    if [[ $exit_code -ne 0 ]]; then
        echo Failed job:$job $source with exit code $exit_code >&2
    fi

    ./complete-production $plan $pos $exit_code $production gen/production.$$ > $plan.$$
    mv $plan.$$ $plan
done

rm -f gen/production.$$

./reduce-productions $plan > gen/roots.$$
if [[ $(wc -l < gen/roots.$$) -eq 1 ]] && ./kgit cat-file blob $(<gen/roots.$$) | grep -qFx exit_code=0; then
    echo status=ok
    echo production=$(<gen/roots.$$)
else
    code=1
    echo status=fail
    awk '{print "partial_production:" NR "=" $0}' gen/roots.$$
fi > gen/invocation.$$
rm gen/roots.$$
echo plan=$initial_plan >> gen/invocation.$$
echo _annotated_plan=$(./kgit hash-object -w --stdin < $plan) >> gen/invocation.$$

sort gen/invocation.$$ | ./kgit hash-object -w --stdin

rm gen/invocation.$$

exit $code
