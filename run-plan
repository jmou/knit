#!/bin/bash -e
#
# Run an execution plan.

plan=$1

set -o pipefail

initial_plan=$(./kgit hash-object -w --stdin < $plan)
./schedule-step $plan > gen/next
while true; do
    [[ $(wc -l < gen/next) -eq 0 ]] && break
    # TODO allow manual jobs
    pos=$(head -n1 gen/next)

    ./extract-step $plan $pos > gen/step
    source=$(grep ^_source= gen/step | cut -d= -f2) || true
    # Convert step to job.
    grep -v ^_ gen/step > gen/job
    # TODO more nuanced caching policy
    job=$(./kgit hash-object -w --stdin < gen/job)

    # TODO completion interface to schedule-step is awkward
    echo -e "_pos=$pos\njob=$job" > gen/completion.$$
    if completion=$(./kgit rev-parse --verify -q refs/job/$job/lastcompletion); then
        ./kgit cat-file blob $completion | grep ^out/ >> gen/completion.$$ || true
        echo _completion=$completion >> gen/completion.$$
        ./schedule-step $plan gen/completion.$$ > gen/next
    else
        echo Running job:$job $source >&2
        ./run-job < gen/job >> gen/completion.$$
        ./schedule-step $plan gen/completion.$$ > gen/next
        completion=$(./extract-step $plan $pos | grep ^_completion= | cut -d= -f2)
        ./kgit update-ref refs/job/$job/lastcompletion $completion
    fi

    ./kgit update-ref refs/lastcompletion $completion
done

rm gen/completion.$$

./kgit hash-object -w --stdin <<EOF
_annotated_plan=$(./kgit hash-object -w --stdin < $plan)
completion=$completion
plan=$initial_plan
EOF
