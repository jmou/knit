#!/usr/bin/python3
#
# Find next steps to run in the execution plan.
# Non-zero exit status if there are no more steps to run.

import sys


schedulable = False

completed = False
unresolved = False
for line in sys.stdin:
    line = line.rstrip('\n')
    if line:
        key, value = line.split('=', 1)
        if key == '_pos':
            pos = value
        elif key.startswith('in/') or key.startswith('inref/'):
            if value.startswith('_pos:'):
                unresolved = True
        elif key == '_dispatch':
            completed = True
    else:
        if not completed and not unresolved:
            print(pos)
            schedulable = True
        completed = False
        unresolved = False

exit(0 if schedulable else 1)
