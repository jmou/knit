# When there was specialized composite process support, this was:
# process=composite:flow/composite/upper.unit
# in/input=inline:abc
process=nested:chmod +x in/unit && in/unit in out/files $(<in/target) in/=file:in/param/ > out/plan
in/unit=file:flow/frontend/unit
in/flow/=file:flow/
in/target=inline:flow/composite/upper.unit
in/param/input=inline:abc
