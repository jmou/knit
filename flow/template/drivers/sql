#!/bin/bash

echo -e '.headers on\n.mode csv' > sql
for i in in/????????????????????????????????????????; do
    # workaround for sqlite <3.34 not quoting table names correctly on .import
    cat >> sql <<EOF
.import "$i" "x${i#in/}"
alter table "x${i#in/}" rename to "$i";
EOF
done
cat $1 >> sql

exec sqlite3 < sql
