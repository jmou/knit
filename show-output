#!/bin/bash -e
#
# Show output from a completion or invocation.

completion_or_invocation=$1
path=$2

completion=$(./kgit cat-file blob $completion_or_invocation | grep ^completion= | cut -d= -f2)
if [[ -z $completion ]]; then
    completion=$completion_or_invocation
fi

cid=$(./kgit cat-file blob $completion | grep "^$path=" | cut -d= -f2)
./kgit cat-file blob $cid
